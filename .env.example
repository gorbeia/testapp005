# Optional: override the default PostHog project API key/host
# (src/analytics.js) for this build, e.g. to point a fork at a different
# PostHog project. See docs/POSTHOG_ANALYTICS.md.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# URL of the feedback worker (worker/), used by the Profile tab's feedback
# form. See docs/CLOUDFLARE_FEEDBACK_WORKER.md. Defaults to the deployed
# worker (hardcoded in src/App.jsx) — only set this to point at a different
# deployment, e.g. a fork's own worker or a local `wrangler dev` instance.
VITE_FEEDBACK_API_URL=

# URL of the sync worker (sync-worker/), used by the Profile tab's
# sign-in/sync feature. See docs/CLOUDFLARE_SYNC_WORKER.md. Defaults to the
# deployed worker (hardcoded in src/App.jsx) — only set this to point at a
# different deployment, e.g. a fork's own worker or a local `wrangler dev`
# instance.
VITE_SYNC_API_URL=
